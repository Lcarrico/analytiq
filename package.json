{
  "name": "analytiq",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client"],
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"python server/app.py\" \"npm run dev --workspace=client\"",
    "dev:server": "python server/app.py",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
