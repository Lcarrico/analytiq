PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost/analytiq_dev

# Fernet key for encrypting warehouse credentials at rest.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Redis URL for rate-limiter storage (optional — falls back to in-memory).
# REDIS_URL=redis://localhost:6379/0

# Resend transactional email (optional — logs to stdout if not set).
# RESEND_API_KEY=re_xxxxxxxxx
# FROM_EMAIL=AnalytIQ <noreply@yourdomain.com>

# Stripe billing (required for subscription features).
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
# STRIPE_PRO_PRICE_ID=price_xxxxxxxxx

# BigQuery connector requires google-cloud-bigquery.
# Service account JSON is provided per-connection in the UI.
# No server-level env var needed — credentials are stored encrypted per connection.
