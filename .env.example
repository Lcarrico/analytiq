# AnalytIQ server environment — EVERYTHING here is optional.
# With no .env at all, the platform boots fully in local mode
# (verify: GET /api/platform/status → all 8 services "local").

PORT=3001
# SQLite database file (default: ./analytiq.db, auto-created + demo-seeded)
# DATABASE_PATH=./analytiq.db

# Speed up / slow down the simulated governance + pipeline runs (tests use ~0)
# SIM_DELAY_SCALE=1

# Fernet key for encrypting warehouse credentials at rest.
# Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CREDENTIAL_ENCRYPTION_KEY=

# Redis URL for rate-limiter storage (falls back to in-memory).
# REDIS_URL=redis://localhost:6379/0

# Resend transactional email (logs to stdout if not set).
# RESEND_API_KEY=re_xxxxxxxxx
# FROM_EMAIL=AnalytIQ <noreply@yourdomain.com>

# Stripe billing (only needed for live subscription features).
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
# STRIPE_PRO_PRICE_ID=price_xxxxxxxxx

# BigQuery source connector: service-account JSON is provided per-connection
# in the UI and stored encrypted — no server-level env var needed.
